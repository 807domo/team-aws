    session = TestSession()

    # テスト用コースを作成
    course = CourseModel(
        id="course-chuyo-basic",
        name="松山城コース（基礎）",
        region="中予",
        difficulty="基礎",
        description="中予地域の基礎コース",
    )
    session.add(course)
    session.commit()

