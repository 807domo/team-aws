{% block scripts %}
<script src="/static/js/map-interactions.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // マップエリアクリック時のタブ連動
    document.querySelectorAll('.map-area').forEach(function(area) {
        area.addEventListener('click', function() {
            var region = this.dataset.region;
            selectMapRegion(region);
        });

        // Enterキー対応
        area.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                var region = this.dataset.region;
                selectMapRegion(region);
                this.click();
            }
        });
    });

    // HTMX afterSwap でタブとマップの状態を同期
    document.body.addEventListener('htmx:afterSwap', function(e) {
        if (e.detail.target.id === 'course-panel') {
            var trigger = e.detail.requestConfig.elt;
            var region = trigger.dataset.region;
            if (region) {
                selectMapRegion(region);
                syncTabs(region);
            }
        }
    });
});

function selectMapRegion(region) {
    // マップの選択状態を更新（排他制御）
    document.querySelectorAll('.map-area').forEach(function(area) {
        area.classList.toggle('selected', area.dataset.region === region);
    });
    syncTabs(region);
}

function syncTabs(region) {
    // タブの選択状態を同期
    document.querySelectorAll('.region-tab').forEach(function(tab) {
        var isActive = tab.dataset.region === region;
        tab.classList.toggle('bg-orange-500', isActive);
        tab.classList.toggle('text-white', isActive);
        tab.classList.toggle('bg-gray-200', !isActive);
        tab.classList.toggle('text-gray-700', !isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
}
</script>
