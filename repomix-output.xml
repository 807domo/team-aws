    engine: MockExamEngine = Depends(get_mock_exam_engine),
):
    """試験を終了し結果画面を表示する（GET: タイマー切れリダイレクト用）。

    Requirements: 5.3
    """
    try:
        result = engine.finish_exam(session_id)
    except ValueError:
        return RedirectResponse(
