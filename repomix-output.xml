from datetime import datetime

import pytest

from app.domain.models import AnswerRecord
from app.domain.progress_calculator import ProgressStatus, calculate_region_progress


def _make_answer_record(
    question_id: str,
    course_id: str,
    is_correct: bool,
    user_id: str = "user-1",
) -> AnswerRecord:
