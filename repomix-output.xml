        redirect_url = response.headers["location"]
        session_id = redirect_url.split("/quiz/")[1].split("/question")[0]

        # 3. dogo-ai-basic コースの問題IDリスト（シードデータから）
        dogo_question_ids = [
            "q-ai-001",
