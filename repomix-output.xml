<file path="app/templates/mock_exam.html">
{% extends "base.html" %}

{% block title %}模擬試験 - 問題 {{ current_index + 1 }} / {{ total_questions }} | 愛媛探索AIクイズ{% endblock %}

{% block head_extra %}
<style>
    .exam-container {
        display: grid;
        grid-template-columns: 1fr 250px;
        gap: 1.5rem;
