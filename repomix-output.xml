    return regions


def detect_themes_in_trivia(trivia: str) -> set:
    """トリビアテキストから参照されているテーマを検出"""
    themes = set()
    for theme, keywords in THEME_KEYWORDS.items():
        for keyword in keywords:
            if keyword in trivia:
                themes.add(theme)
