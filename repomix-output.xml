    Base.metadata.create_all(bind=engine)
    TestSession = sessionmaker(bind=engine)
    db = TestSession()

    # テスト用の基本データを投入
    user = UserModel(id="user-1", display_name="テストユーザー")
    course = CourseModel(
        id="course-1",
