    }

    .timer {
        font-size: 1.5rem;
        font-weight: bold;
        color: #333;
        font-family: monospace;
    }

    .timer.warning {
        color: #e67e22;
    }

    .timer.danger {
        color: #e74c3c;
        animation: blink 1s ease-in-out infinite;
    }

    @keyframes blink {
        50% { opacity: 0.5; }
    }

    .exam-info {
        font-size: 0.9rem;
        color: #666;
    }

    .question-panel {
        padding: 1.5rem;
        background: #fff;
        border-radius: 8px;
        border: 1px solid #dee2e6;
    }

    .question-number {
        font-size: 0.9rem;
        color: #666;
        margin-bottom: 0.5rem;
    }

    .question-text {
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .choices-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .choice-item {
        margin-bottom: 0.75rem;
    }

    .choice-label {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 1rem;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        cursor: pointer;
        transition: border-color 0.2s, background-color 0.2s;
    }

    .choice-label:hover {
        border-color: #3498db;
        background-color: #f0f8ff;
    }

    .choice-label.selected {
        border-color: #3498db;
        background-color: #e8f4fd;
    }

    .choice-radio {
        margin-top: 0.2rem;
    }

    .choice-text {
        flex: 1;
        line-height: 1.5;
    }

    .answer-actions {
        margin-top: 1.5rem;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .nav-panel {
        padding: 1rem;
        background: #fff;
        border-radius: 8px;
        border: 1px solid #dee2e6;
    }

    .nav-panel h4 {
        margin-bottom: 0.75rem;
        font-size: 0.9rem;
        color: #666;
    }

    .nav-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.4rem;
    }

    .nav-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        font-size: 0.8rem;
        text-decoration: none;
        color: #333;
        background: #fff;
        transition: background-color 0.2s;
    }

    .nav-btn:hover {
        background: #f0f8ff;
    }

    .nav-btn.current {
        border-color: #3498db;
        background: #3498db;
        color: #fff;
    }

    .nav-btn.answered {
        background: #d4edda;
        border-color: #28a745;
    }

    .nav-btn.unanswered {
        background: #fff3cd;
        border-color: #ffc107;
    }

    .nav-legend {
        margin-top: 0.75rem;
        font-size: 0.75rem;
        color: #666;
    }

    .nav-legend span {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        margin-right: 0.5rem;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 2px;
    }

    .legend-dot.answered { background: #d4edda; border: 1px solid #28a745; }
    .legend-dot.unanswered { background: #fff3cd; border: 1px solid #ffc107; }
    .legend-dot.current { background: #3498db; }

    .submit-section {
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px solid #dee2e6;
    }

    .btn-finish {
        width: 100%;
        padding: 0.75rem;
        background: #e74c3c;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .btn-finish:hover {
        background: #c0392b;
    }

    .btn { 
        padding: 0.6rem 1.2rem;
        border: none;
        border-radius: 6px;
        font-size: 0.95rem;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary { background: #3498db; color: #fff; }
    .btn-primary:hover { background: #2980b9; }
    .btn-secondary { background: #95a5a6; color: #fff; }
    .btn-secondary:hover { background: #7f8c8d; }
</style>
{% endblock %}

{% block content %}
<div class="exam-container">
    <!-- ヘッダー: タイマー + 試験情報 -->
    <div class="exam-header">
        <div class="exam-info">
            <strong>{{ exam_type_label }}</strong> — 
            問題 {{ current_index + 1 }} / {{ total_questions }}
        </div>
        <div class="timer" id="countdown-timer" data-remaining="{{ remaining_seconds }}">
            <span id="timer-display">--:--</span>
        </div>
    </div>

    <!-- メイン: 問題表示 -->
    <div class="question-panel">
        <p class="question-number">問題 {{ current_index + 1 }}</p>
        <p class="question-text">{{ question_view.question.text }}</p>

        <form method="post" action="/mock-exam/{{ session_id }}/answer" id="answer-form">
            <input type="hidden" name="question_id" value="{{ question_view.question.id }}">
            <input type="hidden" name="question_index" value="{{ current_index }}">

            <ul class="choices-list">
                {% for choice in choices %}
                <li class="choice-item">
                    <label class="choice-label {% if question_view.selected_choice_index == loop.index0 %}selected{% endif %}">
                        <input 
                            type="radio" 
                            name="choice_index" 
                            value="{{ loop.index0 }}"
                            class="choice-radio"
                            {% if question_view.selected_choice_index == loop.index0 %}checked{% endif %}
                        >
                        <span class="choice-text">{{ choice }}</span>
                    </label>
                </li>
                {% endfor %}
            </ul>

            <div class="answer-actions">
                <button type="submit" class="btn btn-primary">回答を記録</button>
                {% if current_index > 0 %}
                <a href="/mock-exam/{{ session_id }}/question/{{ current_index - 1 }}" class="btn btn-secondary">← 前の問題</a>
                {% endif %}
                {% if current_index < total_questions - 1 %}
                <a href="/mock-exam/{{ session_id }}/question/{{ current_index + 1 }}" class="btn btn-secondary">次の問題 →</a>
                {% endif %}
            </div>
        </form>
    </div>

    <!-- サイドバー: ナビゲーション -->
    <div class="nav-panel">
        <h4>問題ナビゲーション</h4>
        <div class="nav-grid">
            {% for i in range(total_questions) %}
            <a 
                href="/mock-exam/{{ session_id }}/question/{{ i }}"
                class="nav-btn {% if i == current_index %}current{% elif answer_status.get(i, false) %}answered{% else %}unanswered{% endif %}"
                aria-label="問題 {{ i + 1 }}{% if answer_status.get(i, false) %}（回答済み）{% else %}（未回答）{% endif %}"
            >
                {{ i + 1 }}
            </a>
            {% endfor %}
        </div>
        <div class="nav-legend">
            <span><span class="legend-dot current"></span>現在</span>
            <span><span class="legend-dot answered"></span>回答済</span>
            <span><span class="legend-dot unanswered"></span>未回答</span>
        </div>

        <div class="submit-section">
            <form method="post" action="/mock-exam/{{ session_id }}/finish" id="finish-form">
                <button type="submit" class="btn-finish" onclick="return confirmFinish()">
                    🏁 提出する
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
(function() {
    // =================================================================
    // カウントダウンタイマー (Requirements: 5.2)
    // =================================================================
    const timerEl = document.getElementById('countdown-timer');
    const displayEl = document.getElementById('timer-display');
    let remainingSeconds = parseInt(timerEl.dataset.remaining, 10);

    function updateTimerDisplay() {
        const minutes = Math.floor(remainingSeconds / 60);
        const seconds = remainingSeconds % 60;
        displayEl.textContent = 
            String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');

        // 色の切り替え
        timerEl.classList.remove('warning', 'danger');
        if (remainingSeconds <= 300) {
            timerEl.classList.add('danger');
        } else if (remainingSeconds <= 600) {
            timerEl.classList.add('warning');
        }
    }

    function tick() {
        remainingSeconds--;
        if (remainingSeconds <= 0) {
            // タイマー切れ: 自動提出
            displayEl.textContent = '00:00';
            window.removeEventListener('beforeunload', onBeforeUnload);
            window.location.href = '/mock-exam/{{ session_id }}/finish';
            return;
        }
        updateTimerDisplay();
    }

    updateTimerDisplay();
    setInterval(tick, 1000);

    // =================================================================
    // ページ離脱確認ダイアログ (Requirements: 5.5)
    // =================================================================
    function onBeforeUnload(e) {
        e.preventDefault();
        e.returnValue = '進行中の試験があります。離脱すると進捗が失われます。';
        return e.returnValue;
    }
    window.addEventListener('beforeunload', onBeforeUnload);

    // フォーム送信時は離脱確認を外す
    document.querySelectorAll('form').forEach(function(form) {
        form.addEventListener('submit', function() {
            window.removeEventListener('beforeunload', onBeforeUnload);
        });
    });

    // ナビゲーションリンク用も離脱確認を外す
    document.querySelectorAll('.nav-btn, .btn-secondary').forEach(function(link) {
        link.addEventListener('click', function() {
            window.removeEventListener('beforeunload', onBeforeUnload);
        });
    });

    // =================================================================
    // 提出確認ダイアログ
    // =================================================================
    window.confirmFinish = function() {
        return confirm('模擬試験を提出しますか？\n未回答の問題は不正解として扱われます。');
    };

    // =================================================================
    // 選択肢のハイライト
    // =================================================================
    document.querySelectorAll('.choice-label').forEach(function(label) {
        label.addEventListener('click', function() {
            document.querySelectorAll('.choice-label').forEach(function(l) {
                l.classList.remove('selected');
            });
            this.classList.add('selected');
        });
    });
})();
</script>
{% endblock %}
</file>

<file path="app/templates/quiz.html">
{% extends "base.html" %}

{% block title %}問題 {{ question_index + 1 }} / {{ total_questions }} - 愛媛探索AIクイズ{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto">
    <!-- 進捗バー -->
    <div class="mb-6">
        <div class="flex justify-between text-sm text-gray-600 mb-1">
            <span>問題 {{ question_index + 1 }} / {{ total_questions }}</span>
            <span>{{ progress_percent }}%</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-3">
            <div class="bg-orange-500 h-3 rounded-full transition-all duration-300"
                 style="width: {{ progress_percent }}%"></div>
        </div>
    </div>

    <!-- 問題カード -->
    <div class="bg-white rounded-lg shadow-md p-6">
        <!-- 問題文 -->
        <div class="mb-6">
            <h2 class="text-lg font-semibold text-gray-800 leading-relaxed">
                {{ question.text }}
            </h2>
        </div>

        <!-- 4択回答フォーム -->
        <form method="post"
              action="/quiz/{{ session_id }}/answer"
              id="answer-form">
            <input type="hidden" name="question_id" value="{{ question.id }}">
            <input type="hidden" name="question_index" value="{{ question_index }}">

            <div class="space-y-3">
                {% for choice in choices %}
                <label class="block cursor-pointer">
                    <input type="radio"
                           name="choice_index"
                           value="{{ loop.index0 }}"
                           class="hidden peer"
                           required>
                    <div class="border-2 border-gray-200 rounded-lg p-4
                                peer-checked:border-orange-500 peer-checked:bg-orange-50
                                hover:border-orange-300 hover:bg-orange-25
                                transition-all duration-200">
                        <div class="flex items-center">
                            <span class="inline-flex items-center justify-center w-8 h-8
                                         rounded-full bg-gray-100 text-gray-600 font-bold mr-3
                                         peer-checked:bg-orange-500 peer-checked:text-white">
                                {{ ['A', 'B', 'C', 'D'][loop.index0] }}
                            </span>
                            <span class="text-gray-700">{{ choice }}</span>
                        </div>
                    </div>
                </label>
                {% endfor %}
            </div>

            <!-- 回答ボタン -->
            <div class="mt-6">
                <button type="submit"
                        class="w-full bg-orange-600 text-white py-3 px-6 rounded-lg
                               font-semibold hover:bg-orange-700
                               disabled:bg-gray-300 disabled:cursor-not-allowed
                               transition-colors duration-200"
                        id="submit-btn"
                        disabled>
                    回答する
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    // 選択肢が選ばれたら回答ボタンを有効化
    document.querySelectorAll('input[name="choice_index"]').forEach(radio => {
        radio.addEventListener('change', () => {
            document.getElementById('submit-btn').disabled = false;
        });
    });
</script>
{% endblock %}
</file>

