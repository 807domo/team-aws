/* =============================================================================
   愛媛探索AIクイズ - スタイルシート
   ============================================================================= */

/* リセット & ベース */
*,
*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

:root {
    --color-primary: #e67e22;
    --color-primary-dark: #d35400;
    --color-secondary: #27ae60;
    --color-bg: #fefefe;
    --color-bg-alt: #f9f9f9;
    --color-text: #333;
    --color-text-light: #666;
    --color-border: #e0e0e0;
    --color-badge-basic: #3498db;
    --color-badge-intermediate: #f39c12;
    --color-badge-advanced: #e74c3c;
    --color-coming-soon: #95a5a6;
    --radius: 8px;
    --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    --shadow-hover: 0 4px 16px rgba(0, 0, 0, 0.12);
    --transition: 0.2s ease;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Sans",
        "Noto Sans JP", sans-serif;
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1rem;
}

a {
    color: var(--color-primary);
    text-decoration: none;
}

a:hover {
    color: var(--color-primary-dark);
}

/* ヘッダー */
.app-header {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    padding: 1.5rem 0;
    text-align: center;
}

.app-title {
    font-size: 1.5rem;
    font-weight: 700;
}

.app-title a {
    color: white;
    text-decoration: none;
}

.app-subtitle {
    font-size: 0.9rem;
    opacity: 0.9;
    margin-top: 0.25rem;
}

/* メインコンテンツ */
main {
    flex: 1;
    padding: 2rem 0;
}

/* フッター */
.app-footer {
    background-color: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    padding: 1rem 0;
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.8rem;
}

/* セクション */
.section-title {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
}

.section-description {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
}

/* 地域タブ */
.region-tabs {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    border-bottom: none;
    padding-bottom: 0;
}

.region-tab {
    padding: 0.85rem 1.8rem;
    border: 2px solid var(--color-border);
    background: var(--color-bg-alt);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-light);
    cursor: pointer;
    border-radius: 999px;
    transition: all 0.25s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.region-tab:hover {
    color: var(--color-primary);
    background: #fff3e0;
    border-color: var(--color-primary);
}

.region-tab.active {
    color: white;
    background: var(--color-primary);
    border-color: var(--color-primary);
    box-shadow: 0 3px 10px rgba(230, 126, 34, 0.3);
}

/* タブパネル */
.region-panel {
    display: none;
}

.region-panel.active {
    display: block;
}

/* コースグリッド */
.course-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
}

/* コースカード */
.course-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    box-shadow: var(--shadow);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
}

.course-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
}

.course-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
}

.course-name {
    font-size: 1.1rem;
    font-weight: 600;
}

.course-description {
    color: var(--color-text-light);
    font-size: 0.9rem;
    flex: 1;
    margin-bottom: 1rem;
}

.course-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.course-meta {
    font-size: 0.8rem;
    color: var(--color-text-light);
}

/* バッジ */
.badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
}

.badge-difficulty {
    color: white;
}

.badge-basic {
    background-color: var(--color-badge-basic);
}

.badge-intermediate {
    background-color: var(--color-badge-intermediate);
}

.badge-advanced {
    background-color: var(--color-badge-advanced);
}

.badge-coming-soon {
    background-color: var(--color-coming-soon);
    color: white;
}

/* ボタン */
.btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    cursor: pointer;
    transition: var(--transition);
    border: none;
    text-decoration: none;
}

.btn-primary {
    background-color: var(--color-primary);
    color: white;
}

.btn-primary:hover {
    background-color: var(--color-primary-dark);
    color: white;
}

/* 空状態（準備中） */
.empty-state {
    text-align: center;
    padding: 3rem 1rem;
    background-color: var(--color-bg-alt);
    border-radius: var(--radius);
    border: 1px dashed var(--color-border);
}

.empty-state-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
}

.empty-state-text {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
}

.empty-state-subtext {
    color: var(--color-text-light);
    font-size: 0.9rem;
}

/* レスポンシブ */
@media (max-width: 600px) {
    .region-tabs {
        flex-wrap: wrap;
    }

    .region-tab {
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
    }

    .course-grid {
        grid-template-columns: 1fr;
    }

    .course-card-footer {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.75rem;
    }

    .btn-primary {
        width: 100%;
    }
}

/* =============================================================================
   コースカード - クリッカブルデザイン
   ============================================================================= */

.course-card-form {
    display: block;
}

.course-card-clickable {
    width: 100%;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    position: relative;
    border: 2px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    background: white;
    box-shadow: var(--shadow);
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.course-card-clickable:hover {
    border-color: var(--color-primary);
    box-shadow: 0 6px 20px rgba(230, 126, 34, 0.2);
    transform: translateY(-3px);
}

.course-card-clickable:active {
    transform: translateY(0);
    box-shadow: var(--shadow);
}

.course-card-meta {
    color: var(--color-text-light);
    font-size: 0.85rem;
}

.course-card-action {
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
}

.btn-start {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.9rem 1rem;
    background: linear-gradient(135deg, var(--color-primary), #f39c12);
    color: white;
    border-radius: var(--radius);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    transition: all 0.25s ease;
    box-shadow: 0 3px 8px rgba(230, 126, 34, 0.3);
}

.course-card-clickable:hover .btn-start {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    box-shadow: 0 4px 12px rgba(230, 126, 34, 0.4);
    transform: scale(1.02);
}
