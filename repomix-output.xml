        <a href="/" class="inline-block mt-4 bg-orange-600 text-white px-6 py-2 rounded-lg hover:bg-orange-700 transition">
            コース選択へ
        </a>
    </div>
    {% else %}

    <!-- スコア・グレード表示セクション -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-lg shadow p-6 text-center">
            <h2 class="text-sm font-semibold text-gray-500 uppercase mb-2">累計正答率</h2>
            <p class="text-5xl font-bold text-orange-600">{{ "%.1f"|format(cumulative_accuracy) }}%</p>
        </div>
        <div class="bg-white rounded-lg shadow p-6 text-center">
            <h2 class="text-sm font-semibold text-gray-500 uppercase mb-2">グレード</h2>
            <p class="text-5xl font-bold
                {% if grade == 'A' %}text-green-600
                {% elif grade == 'B' %}text-blue-600
                {% elif grade == 'C' %}text-yellow-600
                {% elif grade == 'D' %}text-orange-600
                {% else %}text-red-600{% endif %}
            ">{{ grade }}</p>
        </div>
    </div>

    <!-- レーダーチャートセクション -->
    <div class="bg-white rounded-lg shadow p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-gray-800">🎯 ドメイン別正答率</h2>
            <div class="flex gap-2">
                <button id="btn-cloud-practitioner"
                        class="exam-type-btn px-3 py-1 text-sm rounded-full bg-orange-600 text-white"
                        data-exam-type="AWS Certified Cloud Practitioner">
                    Cloud Practitioner
                </button>
                <button id="btn-ai-practitioner"
                        class="exam-type-btn px-3 py-1 text-sm rounded-full bg-gray-200 text-gray-700 hover:bg-gray-300"
                        data-exam-type="AWS AI Practitioner">
                    AI Practitioner
                </button>
            </div>
        </div>
        <div class="flex justify-center">
            <canvas id="radarChart" width="400" height="400"></canvas>
        </div>
    </div>

    <!-- 愛媛探索率セクション -->
    <div class="bg-white rounded-lg shadow p-6 mb-8">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">🍊 愛媛探索率</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="text-center p-4 bg-orange-50 rounded-lg">
                <p class="text-3xl font-bold text-orange-600">{{ "%.1f"|format(exploration_rate.exploration_percentage) }}%</p>
                <p class="text-sm text-gray-600 mt-1">探索率</p>
            </div>
            <div class="text-center p-4 bg-orange-50 rounded-lg">
                <p class="text-3xl font-bold text-orange-600">{{ exploration_rate.completed_courses }}/{{ exploration_rate.total_courses }}</p>
                <p class="text-sm text-gray-600 mt-1">コース完了</p>
            </div>
            <div class="text-center p-4 bg-orange-50 rounded-lg">
                <p class="text-3xl font-bold text-orange-600">{{ exploration_rate.completed_region_count }}/3</p>
                <p class="text-sm text-gray-600 mt-1">地域探索済み</p>
            </div>
        </div>
    </div>

    <!-- 学習履歴セクション -->
    <div class="bg-white rounded-lg shadow p-6 mb-8">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">📈 学習履歴</h2>

        {% if attempt_history|length >= 2 %}
        <!-- 学習履歴グラフ -->
        <div class="mb-6">
            <canvas id="historyChart" width="600" height="250"></canvas>
        </div>
        {% endif %}

        <!-- 学習履歴テーブル -->
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                    <tr>
                        <th class="px-4 py-3">日時</th>
                        <th class="px-4 py-3">コース名</th>
                        <th class="px-4 py-3">正答率</th>
                        <th class="px-4 py-3">グレード</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    {% for attempt in attempt_history %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 text-gray-600">{{ attempt.completed_at }}</td>
                        <td class="px-4 py-3 font-medium text-gray-800">{{ attempt.course_name }}</td>
                        <td class="px-4 py-3 text-gray-700">{{ "%.1f"|format(attempt.accuracy_rate) }}%</td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-1 rounded-full text-xs font-semibold
                                {% if attempt.grade == 'A' %}bg-green-100 text-green-800
                                {% elif attempt.grade == 'B' %}bg-blue-100 text-blue-800
                                {% elif attempt.grade == 'C' %}bg-yellow-100 text-yellow-800
                                {% elif attempt.grade == 'D' %}bg-orange-100 text-orange-800
                                {% else %}bg-red-100 text-red-800{% endif %}
                            ">{{ attempt.grade }}</span>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% endif %}
</div>
{% endblock %}

{% block scripts %}
{% if has_history %}
<script>
// レーダーチャートの初期データ
const radarLabels = {{ radar_labels | tojson }};
const radarValues = {{ radar_values | tojson }};

// レーダーチャート描画
const radarCtx = document.getElementById('radarChart').getContext('2d');
const radarChart = new Chart(radarCtx, {
    type: 'radar',
    data: {
        labels: radarLabels,
        datasets: [{
            label: '正答率 (%)',
            data: radarValues,
            backgroundColor: 'rgba(234, 88, 12, 0.2)',
            borderColor: 'rgba(234, 88, 12, 1)',
            borderWidth: 2,
            pointBackgroundColor: 'rgba(234, 88, 12, 1)',
            pointBorderColor: '#fff',
            pointHoverBackgroundColor: '#fff',
            pointHoverBorderColor: 'rgba(234, 88, 12, 1)',
        }]
    },
    options: {
        responsive: true,
        scales: {
            r: {
                beginAtZero: true,
                max: 100,
                ticks: {
                    stepSize: 20,
                },
                pointLabels: {
                    font: { size: 11 }
                }
            }
        },
        plugins: {
            legend: { display: false }
        }
    }
});

// 試験タイプ切り替えボタン
document.querySelectorAll('.exam-type-btn').forEach(btn => {
    btn.addEventListener('click', async function() {
        // ボタンスタイル切り替え
        document.querySelectorAll('.exam-type-btn').forEach(b => {
            b.classList.remove('bg-orange-600', 'text-white');
            b.classList.add('bg-gray-200', 'text-gray-700');
        });
        this.classList.remove('bg-gray-200', 'text-gray-700');
        this.classList.add('bg-orange-600', 'text-white');

        // レーダーチャートデータを取得
        const examType = this.dataset.examType;
        const response = await fetch(`/results/radar-chart?exam_type=${encodeURIComponent(examType)}`);
        const data = await response.json();

        // チャートを更新
        radarChart.data.labels = data.labels;
        radarChart.data.datasets[0].data = data.values;
        radarChart.update();
    });
});

// 学習履歴グラフ
{% if attempt_history|length >= 2 %}
const historyData = {{ attempt_history | tojson }};
const historyCtx = document.getElementById('historyChart').getContext('2d');
new Chart(historyCtx, {
    type: 'line',
    data: {
        labels: historyData.map(a => a.completed_at),
        datasets: [{
            label: '正答率 (%)',
            data: historyData.map(a => a.accuracy_rate),
            borderColor: 'rgba(234, 88, 12, 1)',
            backgroundColor: 'rgba(234, 88, 12, 0.1)',
            borderWidth: 2,
            fill: true,
            tension: 0.3,
            pointBackgroundColor: 'rgba(234, 88, 12, 1)',
            pointRadius: 4,
        }]
    },
    options: {
        responsive: true,
        scales: {
            y: {
                beginAtZero: true,
                max: 100,
                title: { display: true, text: '正答率 (%)' }
            },
            x: {
                title: { display: true, text: '受験日時' },
                ticks: {
                    maxRotation: 45,
                    minRotation: 45,
                }
            }
        },
        plugins: {
            legend: { display: false }
        }
    }
});
{% endif %}
</script>
{% endif %}
{% endblock %}
</file>

