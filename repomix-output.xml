            _make_answer_record("q1", "course-1", is_correct=True),
            _make_answer_record("q2", "course-1", is_correct=False),
        ]
        result = calculate_region_progress(
            region="NANYO",
            courses_in_region=["course-1"],
            user_answer_records=records,
            course_questions={
                "course-1": ["q1", "q2"],
            },
        )
