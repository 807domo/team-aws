            self._make_record("q3", False),
        ]
        domains = {"q1": "Security", "q2": "Security", "q3": "Security"}
        # 1/3 incorrect = 33.3% >= 30% threshold
        result = identify_weak_areas(records, domains, threshold=0.3)
